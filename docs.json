{
  "$schema": "https://mintlify.com/docs.json",
  "name": "neo-git-graph",
  "theme": "mint",
  "colors": {
    "primary": "#0085d9",
    "light": "#0085d9",
    "dark": "#0085d9"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/asispts/neo-git-graph"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/asispts/neo-git-graph"
    }
  },
  "navigation": {
