          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/overview",
              "configuration/display-settings",
              "configuration/performance-settings"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/devcontainer-setup",
